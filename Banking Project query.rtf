\f0\fs24 \cf0 CREATE database Banking_transactions;\
\
USE Banking_transactions;\
\
CREATE TABLE users (\
    id VARCHAR(50),\
    current_age INT,\
    retirement_age INT,\
    birth_year INT,\
    birth_month INT,\
    gender VARCHAR(10),\
    address VARCHAR(255),\
    latitude DECIMAL(10,6),\
    longitude DECIMAL(10,6),\
    per_capita_income DECIMAL(12,2),\
    yearly_income DECIMAL(12,2),\
    total_debt DECIMAL(12,2),\
    credit_score INT,\
    num_credit_cards INT\
);\
\
CREATE TABLE cards (\
    id VARCHAR(50),\
    client_id VARCHAR(50),\
    card_brand VARCHAR(20),\
    card_type VARCHAR(20),\
    card_number VARCHAR(30),\
    expires VARCHAR(10),\
    cvv INT,\
    has_chip VARCHAR(10),\
    num_cards_issued INT,\
    credit_limit DECIMAL(12,2),\
    acct_open_date DATE,\
    year_pin_last_changed INT,\
    card_on_dark_web VARCHAR(10)\
);\
\
CREATE TABLE transactions (\
    id VARCHAR(50),\
    date DATETIME,\
    client_id VARCHAR(50),\
    card_id VARCHAR(50),\
    amount VARCHAR(20),\
    use_chip VARCHAR(100),\
    merchant_id VARCHAR(50),\
    merchant_city VARCHAR(100),\
    merchant_state VARCHAR(20),\
    zip VARCHAR(20),\
    mcc VARCHAR(20),\
    errors VARCHAR(100)\
);\
\
