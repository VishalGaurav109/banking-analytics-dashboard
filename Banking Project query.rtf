--  Validate JOINS\
\
SELECT COUNT(*)\
FROM transactions t\
JOIN users u \
ON t.client_id = u.id;\
\
\
SELECT COUNT(*)\
FROM transactions t\
JOIN cards c \
ON t.card_id = c.id;\
\
-- CORE KPIs\
\
-- Remove $\
\
SET SQL_SAFE_UPDATES = 0;\
\
UPDATE transactions\
SET amount = REPLACE(amount, '$', '');\
\
UPDATE transactions\
SET amount = REPLACE(amount, ',', '');\
\
SELECT amount FROM transactions;\
\
\
-- CORE KPIs\
SELECT COUNT(*) AS total_transactions \
FROM transactions;\
\
SELECT SUM(amount) AS total_spend \
FROM transactions;\
\
SELECT AVG(amount) AS avg_transaction \
FROM transactions;\
\
SELECT COUNT(DISTINCT client_id) \
FROM transactions;\
\
\
-- BUSINESS INSIGHTS\
\
 -- Monthly Spend Trend\
SELECT \
    DATE_FORMAT(date, '%Y-%m') AS month,\
    SUM(amount) AS total_spend\
FROM transactions\
GROUP BY month\
ORDER BY month;\
\
 -- Top Spending Users\
SELECT \
    client_id,\
    SUM(amount) AS total_spent\
FROM transactions\
GROUP BY client_id\
ORDER BY total_spent DESC\
LIMIT 10;\
\
-- Card Type Analysis\
SELECT \
    c.card_type,\
    SUM(t.amount) AS total_spend\
FROM transactions t\
JOIN cards c \
ON t.card_id = c.id\
GROUP BY c.card_type;\
\
-- High Spending + Low Credit Score\
\
SELECT \
    u.id,\
    u.credit_score,\
    SUM(t.amount) AS total_spent\
FROM users u\
JOIN transactions t \
ON u.id = t.client_id\
GROUP BY u.id, u.credit_score\
ORDER BY u.credit_score ASC\
LIMIT 10;\
\
-- Top Cities by Spend\
\
SELECT \
    u.address,\
    SUM(t.amount) AS total_spend\
FROM transactions t\
JOIN users u ON t.client_id = u.id\
GROUP BY u.address\
ORDER BY total_spend DESC\
LIMIT 10;\
\
-- Credit Card Usage Distribution\
\
SELECT \
    c.card_type,\
    COUNT(*) AS total_transactions,\
    SUM(t.amount) AS total_spend\
FROM transactions t\
JOIN cards c ON t.card_id = c.id\
GROUP BY c.card_type;\
\
-- Avg Spend by Age Group\
\
SELECT \
    CASE \
        WHEN current_age < 30 THEN 'Under 30'\
        WHEN current_age BETWEEN 30 AND 50 THEN '30-50'\
        ELSE '50+'\
    END AS age_group,\
    AVG(t.amount) AS avg_spend\
FROM users u\
JOIN transactions t ON u.id = t.client_id\
GROUP BY age_group;\
\
-- BI Dashboard \
\
-- 1. KPI Table\
\
SELECT \
    COUNT(*) AS total_transactions,\
    SUM(amount) AS total_spend,\
    AVG(amount) AS avg_transaction,\
    COUNT(DISTINCT client_id) AS total_users\
FROM transactions;\
\
-- 2. Monthly Trend\
SELECT \
    DATE_FORMAT(date, '%Y-%m') AS month,\
    SUM(amount) AS total_spend\
FROM transactions\
GROUP BY month;\
\
-- 3. Card Type\
\
SELECT \
    c.card_type,\
    SUM(t.amount) AS total_spend\
FROM transactions t\
JOIN cards c ON t.card_id = c.id\
GROUP BY c.card_type;\
\
-- 4. Top Users\
\
SELECT \
    client_id,\
    SUM(amount) AS total_spent\
FROM transactions\
GROUP BY client_id\
ORDER BY total_spent DESC\
LIMIT 20;\
\
